{"docker-compose":{"prefix":"justdocker","body":["docker-up:","    docker compose -f ./docker-compose.yml up --detach","","docker-down:","    docker compose -f ./docker-compose.yml down"]},"justgo":{"prefix":"justgo","body":["main_package := \"./cmd/package\"","binary := \"binary\"","","tidy:","    go fmt ./...","    go mod tidy -v","","audit:","    go mod verify","    go vet ./...","    go run honnef.co/go/tools/cmd/staticcheck@latest -checks=all,-ST1000,-U1000 ./...","    go run golang.org/x/vuln/cmd/govulncheck@latest ./...","","","test:","    go test -v -race -buildvcs ./...","","build:","    go build -o=./bin/{{ binary }} {{ main_package }}","","run: build","    ./bin/{{ binary }}","","run-live:","    air --build.cmd \"just build\" \\","        --build.bin \"./bin/{{ binary }}\" \\","        --build.delay \"100\" \\","        --build.exclude_dir \"node_modules\" \\","        --build.include_ext \"go, tpl, tmpl, html, css, scss, js, ts, sql, jpeg, jpg, gif, png, bmp, svg, webp, ico\" \\","        --misc.clean_on_exit \"true\""]}}